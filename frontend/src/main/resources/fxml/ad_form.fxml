<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ir.secondhand.frontend.controller.AdFormController" styleClass="page-background">
    <top>
        <fx:include fx:id="navbar" source="components/navbar.fxml"/>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox alignment="TOP_CENTER" spacing="0">
                <padding>
                    <Insets top="24" bottom="32"/>
                </padding>
                <VBox styleClass="form-container" maxWidth="600" spacing="14">
                    <Label fx:id="formTitleLabel" text="ثبت آگهی جدید" styleClass="form-title"/>
                    <Label text="پس از ثبت یا ویرایش، آگهی شما تا زمان تایید مدیر در انتظار بررسی باقی می‌ماند."
                           styleClass="card-meta" wrapText="true"/>

                    <VBox spacing="6">
                        <Label text="عنوان آگهی" styleClass="field-label"/>
                        <TextField fx:id="titleField" promptText="مثال: گوشی سامسونگ گلکسی S21"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="توضیحات" styleClass="field-label"/>
                        <TextArea fx:id="descriptionField" prefRowCount="5" wrapText="true"
                                  promptText="توضیحات کامل درباره وضعیت، مشخصات و شرایط فروش کالا"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="قیمت (تومان)" styleClass="field-label"/>
                        <TextField fx:id="priceField" promptText="مثال: 5000000"/>
                    </VBox>

                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="دسته‌بندی" styleClass="field-label"/>
                            <ComboBox fx:id="categoryCombo" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="شهر" styleClass="field-label"/>
                            <ComboBox fx:id="cityCombo" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

                    <HBox spacing="10">
                        <Button fx:id="submitButton" text="ثبت آگهی" styleClass="btn-primary" onAction="#onSubmit"/>
                        <Button text="انصراف" styleClass="btn-secondary" onAction="#onCancel"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
