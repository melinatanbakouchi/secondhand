<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ir.secondhand.frontend.controller.HomeController" styleClass="page-background">
    <top>
        <fx:include fx:id="navbar" source="components/navbar.fxml"/>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="18">
                <padding>
                    <Insets top="20" right="24" bottom="24" left="24"/>
                </padding>

                <HBox styleClass="search-bar" spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="keywordField" promptText="جست‌وجو در آگهی‌ها..." HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="categoryCombo" promptText="همه دسته‌بندی‌ها" prefWidth="170"/>
                    <ComboBox fx:id="cityCombo" promptText="همه شهرها" prefWidth="140"/>
                    <TextField fx:id="minPriceField" promptText="حداقل قیمت" prefWidth="110"/>
                    <TextField fx:id="maxPriceField" promptText="حداکثر قیمت" prefWidth="110"/>
                    <Button text="جست‌وجو" styleClass="btn-primary" onAction="#onSearch"/>
                    <Button text="حذف فیلتر" styleClass="btn-secondary" onAction="#onClearFilters"/>
                </HBox>

                <Label fx:id="resultCountLabel" styleClass="section-title"/>
                <Label fx:id="emptyLabel" styleClass="empty-state" text="آگهی‌ای با این مشخصات یافت نشد." managed="false" visible="false"/>

                <FlowPane fx:id="adsContainer" hgap="16" vgap="16"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
